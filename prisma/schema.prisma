generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pearls {
  id        String   @id @unique @default(cuid())
  createdAt DateTime @default(now())
  dimension String
  observer  String
  owner     String
  server    String
  x         Int
  y         Int
  z         Int
}

model Players {
  id        String    @id @unique @default(cuid())
  admin     Boolean   @default(false)
  firstSeen DateTime  @default(now())
  lastSeen  DateTime? @updatedAt
  observer  String
  server    String
  username  String
  uuid      String
  x         Int?
  y         Int?
  z         Int?

  @@unique([observer, server, uuid], name: "observer_server_uuid_unique")
}
