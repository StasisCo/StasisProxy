generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DB_URL")
}

model Stasis {
    id        String   @id @unique @default(cuid())
    createdAt DateTime @default(now())
    dimension String
    observer  String
    owner     String
    server    String
    x         Int
    y         Int
    z         Int
}
