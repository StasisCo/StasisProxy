generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Stasis {
  // Unique ID
  id String @id @default(cuid())

  // Timestamp of when the stasis was created
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // The dimension the stasis is in (e.g., "overworld", "the_nether", "the_end")
  dimension String

  // The block coordinates of the stasis
  x Int
  y Int
  z Int

  // The server the stasis belongs to (e.g., "play.example.com")
  server String

  // The player who owns this stasis
  ownerId String
  owner   Player @relation(fields: [ownerId], references: [id])

  // The bot that is managing this stasis (if any)
  botId String?
  bot   Bot?    @relation(fields: [botId], references: [id])

  // Only 1 stasis can exist at a given position in a given dimension on a given server
  @@unique([server, x, y, z, dimension], name: "position")
}

model Player {
  // A unique ID for the player record
  id String @id @unique

  // Timestamp of when the player record was created
  createdAt DateTime @default(now())

  // The player's UUID (from Mojang) and username
  username String

  // A player can have multiple stasis records
  stasis   Stasis[]
  discords Discord[]

  // Players can sometimes be bots themselves
  bot Bot?

  // Players that connect via the proxy will have a client record
  client Client?
}

model Bot {
  // A unique ID for the bot record
  id String @id @unique

  // Timestamp of when the bot record was created
  createdAt DateTime @default(now())

  // The player instance that this bot is associated with
  player Player @relation(fields: [id], references: [id])

  // Observing stasis
  managing Stasis[]
}

model Discord {
  // The discord user ID
  id String @id @unique

  // Timestamp of when the discord record was created
  createdAt DateTime @default(now())

  // All uuids that this user
  players Player[]
}

model Client {
  // A unique ID for the client record
  id String @id @unique

  // Timestamp of when the client record was created
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Persistent client configuration data
  config Json?

  // Whether this client is whitelisted to bypass queue and stasis checks
  whitelisted Boolean @default(false)

  // The remote address of the client connection (for logging and abuse prevention)
  remoteAddress String?

  // The player instance that this client is associated with
  player Player @relation(fields: [id], references: [id])
}
