{
	"name": "stasis-proxy",
	"version": "1.0.37",
	"module": "src/index.ts",
	"type": "module",
	"scripts": {
		"start": "bun .",
		"dev": "bun . --skip-migrations",
		"lint": "eslint . --fix",
		"generate": "cross-env DATABASE_URL=\"postgresql://\" prisma generate",
		"copy-types": "mkdir -p src/generated/@hackware/types && cp -RL node_modules/@hackware/types/schema src/generated/@hackware/types",
		"build": "docker build -t stasis-proxy ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@prisma/client": "^7.8.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/bun": "latest",
		"@types/lodash": "^4.17.24",
		"@types/node": "^25.6.0",
		"cross-env": "^10.1.0",
		"eslint": "^10.2.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@vermaysha/discord-webhook": "^1.4.0",
		"canvas": "^3.2.3",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"dayjs": "^1.11.20",
		"discord.js": "^14.26.3",
		"eventsource": "^4.1.0",
		"ioredis": "^5.10.1",
		"lodash": "^4.18.1",
		"minecraft-protocol": "^1.66.0",
		"mineflayer": "^4.37.0",
		"mineflayer-armor-manager": "^2.0.1",
		"mineflayer-movement": "^0.4.4",
		"pretty-ms": "^9.3.0",
		"prisma": "^7.8.0",
		"prismarine-block": "^1.23.0",
		"prismarine-chat": "^1.13.0",
		"prismarine-entity": "^2.6.0",
		"prismarine-item": "^1.18.0",
		"prismarine-physics": "^1.11.0",
		"prismarine-viewer": "^1.33.0",
		"sharp": "^0.34.5",
		"strip-ansi": "^7.2.0",
		"vec3": "^0.2.0",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	}
}
